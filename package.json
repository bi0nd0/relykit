{
  "name": "relykit",
  "version": "0.1.0-beta.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bi0nd0/relykit.git"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=22.14 <27",
    "npm": ">=10 <12"
  },
  "scripts": {
    "check:runtime": "node scripts/check-runtime.mjs",
    "preinstall": "node scripts/check-runtime.mjs",
    "build": "npm run build --workspace @relykit/oidc && npm run build --workspace @relykit/nuxt",
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "pack:packages": "npm run pack --workspace @relykit/oidc && npm run pack --workspace @relykit/nuxt",
    "check:packages": "node scripts/check-package-contents.mjs",
    "check:release": "node scripts/check-release.mjs",
    "check": "npm run check:runtime && npm run lint && npm run typecheck && npm run test && npm run build && npm run check:packages",
    "pack:dry-run": "npm pack --dry-run --cache .npm-cache --workspace @relykit/oidc && npm pack --dry-run --cache .npm-cache --workspace @relykit/nuxt"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "1.16.0",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
